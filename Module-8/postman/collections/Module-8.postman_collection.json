      "item": [
        {
          "name": "/tasks (done param)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON array', function () {",
                  "    pm.response.to.be.json;",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Every task matches the done=true and tag=work filters', function () {",
                  "    const tasks = pm.response.json();",
                  "    tasks.forEach(function (t) {",
                  "        pm.expect(t.done).to.eql(true);",
                  "        pm.expect(t.tag).to.eql('work');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Sorted by createdAt desc', function () {",
                  "    const tasks = pm.response.json();",
                  "    for (let i = 1; i < tasks.length; i++) {",
                  "        pm.expect(new Date(tasks[i - 1].createdAt).getTime())",
                  "            .to.be.at.least(new Date(tasks[i].createdAt).getTime());",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "secret123",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{baseUrl}}/tasks?done=true&tag=work",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "done",
                  "value": "true"
                },
                {
                  "key": "tag",
                  "value": "work",
                  "type": "text"
                }
              ]
            }
          },
          "response": []
        },
